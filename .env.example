# ==========================================
# Serverless / Managed Services Environment
# ==========================================

# 1. PostgreSQL (Supabase or Neon)
# Example (Supabase): postgresql://postgres.[project-id]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Example (Neon): postgresql://[user]:[password]@[endpoint].neon.tech/neondb?sslmode=require
DATABASE_URL=your_managed_postgres_url_here

# 2. Redis (Upstash)
# Example: rediss://default:[password]@[endpoint].upstash.io:32453
# Note: MUST start with 'rediss://' (with double 's') for secure TLS connection
REDIS_URL=your_upstash_redis_url_here

# 3. LiveKit Cloud
# Example: wss://[project-name].livekit.cloud
LIVEKIT_URL=your_livekit_cloud_url_here
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# 4. Security
JWT_SECRET=super_secret_key_for_jwt_generation
PORT=8000
